#: includes/modules/class-tsosk-mod-update-manager.php:644
msgid "Partially blocked"
msgstr "Parcialmente bloqueado"

msgid "Custom rules hide some update checks. Automatic updates are managed by WordPress (Dashboard → Updates)."
msgstr "Las reglas personalizadas ocultan algunas comprobaciones de actualización. Las actualizaciones automáticas las gestiona WordPress (Escritorio → Actualizaciones)."

msgid "Not blocking"
msgstr "Sin bloqueos"

msgid "This module is not blocking update checks. Configure automatic updates in Dashboard → Updates."
msgstr "Este módulo no bloquea las comprobaciones de actualización. Configura las actualizaciones automáticas en Escritorio → Actualizaciones."

msgid "Manual update check finished (plugins pending: %1$d → %2$d)."
msgstr "Comprobación manual de actualizaciones finalizada (plugins pendientes: %1$d → %2$d)."

msgid "Update check finished. Pending before — plugins: %1$d, themes: %2$d, translations: %3$d. Pending now — plugins: %4$d, themes: %5$d, translations: %6$d. Install updates from Dashboard → Updates."
msgstr "Comprobación finalizada. Pendientes antes — plugins: %1$d, temas: %2$d, traducciones: %3$d. Pendientes ahora — plugins: %4$d, temas: %5$d, traducciones: %6$d. Instala las actualizaciones desde Escritorio → Actualizaciones."

msgid "Monitor WordPress update status, optionally block update checks (staging), hide specific plugin updates, and control update email notifications."
msgstr "Supervisa el estado de actualizaciones de WordPress, bloquea opcionalmente las comprobaciones (staging), oculta actualizaciones de plugins concretos y controla los correos de notificación."

msgid "WordPress checks wordpress.org for core, plugin, theme and translation updates, can install some automatically, and sends email when updates happen. This module helps you troubleshoot update issues, block update checks when needed, and manage notification emails."
msgstr "WordPress comprueba wordpress.org en busca de actualizaciones del núcleo, plugins, temas y traducciones, puede instalar algunas automáticamente y envía correos cuando hay actualizaciones. Este módulo te ayuda a diagnosticar problemas, bloquear comprobaciones cuando haga falta y gestionar los correos de notificación."

msgid "Dashboard → Updates"
msgstr "Escritorio → Actualizaciones"

msgid "Automatic updates are configured in WordPress itself — go to %s to enable or disable auto-updates per component."
msgstr "Las actualizaciones automáticas se configuran en el propio WordPress — ve a %s para activar o desactivar las auto-actualizaciones por componente."

msgid "If updates stay pending for days, check the blockers below. Use the button to contact wordpress.org and refresh the pending update list (does not install updates)."
msgstr "Si las actualizaciones siguen pendientes durante días, revisa los bloqueos siguientes. Usa el botón para contactar con wordpress.org y actualizar la lista de pendientes (no instala actualizaciones)."

msgid "Check for updates now"
msgstr "Comprobar actualizaciones ahora"

msgid "No overrides — WordPress handles update checks and emails as usual."
msgstr "Sin cambios — WordPress gestiona las comprobaciones y los correos como de costumbre."

msgid "Stop update checks for core, plugins, themes and translations. Hide dashboard nags."
msgstr "Detiene las comprobaciones del núcleo, plugins, temas y traducciones. Oculta los avisos del panel."

msgid "Configure update-check blocking and email options individually."
msgstr "Configura el bloqueo de comprobaciones y las opciones de correo individualmente."

msgid "Hide available updates for specific plugins in the dashboard. Does not change WordPress auto-update settings — use Dashboard → Updates for that."
msgstr "Oculta actualizaciones disponibles de plugins concretos en el panel. No cambia la configuración de auto-actualizaciones de WordPress — usa Escritorio → Actualizaciones para eso."

msgid "Version"
msgstr "Versión"

