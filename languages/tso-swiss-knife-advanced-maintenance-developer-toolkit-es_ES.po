msgstr "Cargando opciones…"

msgid ""
"No .htaccess file was found at the WordPress root. This is normal on Nginx "
"servers. On Apache, it is required for pretty permalinks."
msgstr ""
"No se encontró ningún archivo .htaccess en la raíz de WordPress. Esto es "
"normal en servidores Nginx. En Apache, es necesario para los permalinks "
"bonitos."

msgid ""
"No robots.txt file was found. WordPress may serve a default virtual "
"robots.txt. You can create one here."
msgstr ""
"No se encontró ningún archivo robots.txt. WordPress puede servir un "
"robots.txt virtual predeterminado. Puede crear uno aquí."

msgid ""
"No Sitemap directive was found. Consider adding one so search engines can "
"discover your sitemap directly."
msgstr ""
"No se encontró ninguna directiva Sitemap. Considere añadir una para que los "
"motores de búsqueda puedan descubrir su sitemap directamente."

