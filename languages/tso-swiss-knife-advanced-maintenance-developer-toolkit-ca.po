msgstr "Mode desenvolupador desactivat. Recarrega la pàgina per aplicar-ho."

msgid "Enable developer mode"
msgstr "Activar mode desenvolupador"

msgid "Disable developer mode"
msgstr "Desactivar mode desenvolupador"

msgid ""
"One click: WP_DEBUG + WP_DEBUG_LOG + SAVEQUERIES on, WP_DEBUG_DISPLAY off "
"(safe for staging)."
msgstr ""
"Un clic: WP_DEBUG + WP_DEBUG_LOG + SAVEQUERIES activats, WP_DEBUG_DISPLAY "
"desactivat (segur per staging)."

