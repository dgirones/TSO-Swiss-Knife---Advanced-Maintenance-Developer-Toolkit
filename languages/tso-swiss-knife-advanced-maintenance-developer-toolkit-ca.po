msgstr "DISABLE_WP_CRON està actiu (sovint des de %1$s). Les actualitzacions en segon pla només s'executen si un cron del servidor crida wp-cron.php. Reviseu la pestanya %2$s."

#: includes/modules/class-tsosk-mod-update-manager.php:608
msgid "Hidden Profiles"
msgstr "Perfils ocults"

#: includes/modules/class-tsosk-mod-update-manager.php:611
msgid "WordPress schedules update checks on site traffic (twice daily)."
msgstr "WordPress programa comprovacions d'actualització amb el trànsit del lloc (dos cops al dia)."

#: includes/modules/class-tsosk-mod-update-manager.php:616
msgid "File modifications"
msgstr "Modificacions de fitxers"

#: includes/modules/class-tsosk-mod-update-manager.php:617
#: includes/modules/class-tsosk-mod-update-manager.php:631
