#, php-format
msgid "DISALLOW_FILE_MODS is enabled (%s or wp-config.php). WordPress cannot install updates automatically."
msgstr "DISALLOW_FILE_MODS està actiu (%s o wp-config.php). WordPress no pot instal·lar actualitzacions automàticament."

#: includes/modules/class-tsosk-mod-update-manager.php:625
msgid "The updater can write plugin, theme and translation files."
msgstr "L'actualitzador pot escriure fitxers de plugins, temes i traduccions."

#: includes/modules/class-tsosk-mod-update-manager.php:630
msgid "Automatic updater"
msgstr "Actualitzador automàtic"

#: includes/modules/class-tsosk-mod-update-manager.php:634
msgid "WordPress may run background updates when cron executes."
msgstr "WordPress pot executar actualitzacions en segon pla quan s'executa el cron."

#: includes/modules/class-tsosk-mod-update-manager.php:635
msgid "WordPress core blocked automatic updates for this site."
msgstr "El nucli de WordPress ha bloquejat les actualitzacions automàtiques d'aquest lloc."

#: includes/modules/class-tsosk-mod-update-manager.php:653
msgid "Update Manager policy"
msgstr "Política del gestor d'actualitzacions"

#: includes/modules/class-tsosk-mod-update-manager.php:640
msgid "All blocked"
msgstr "Tot bloquejat"

#: includes/modules/class-tsosk-mod-update-manager.php:642
msgid "Update Manager preset “Disable all updates” is active."
msgstr "El preset del gestor «Desactivar totes les actualitzacions» està actiu."

#: includes/modules/class-tsosk-mod-update-manager.php:661
